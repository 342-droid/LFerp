#!/usr/bin/env sh
# Appends staged diff --stat to the commit message (excludes merge commits).
# Enable: git config core.hooksPath .githooks

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

if [ "$COMMIT_SOURCE" = merge ]; then
  exit 0
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

# Nothing staged — let git handle empty commit error
if ! git diff --cached --quiet 2>/dev/null; then
  {
    echo ""
    echo "---"
    echo "【自动生成 · 暂存区统计】可编辑或删除本段"
    git diff --cached --stat
  } >>"$COMMIT_MSG_FILE"
fi

exit 0
